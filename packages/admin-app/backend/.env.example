# Database Configuration
# Railway provides DATABASE_URL. You can also specify SaaS and Admin DBs separately.
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL_SaaS=postgresql://user:password@host:port/saas_dbname
DATABASE_URL_ADMIN=postgresql://user:password@host:port/admin_dbname

# Security
ADMIN_SECRET=developer_secret_key_2026
JWT_SECRET=your_random_jwt_secret_here

# Connection Links (For cross-service reference)
RAILWAY_SAAS_LINK=https://your-main-saas-backend.up.railway.app
VERCEL_SAAS_LINK=https://your-main-saas-frontend.vercel.app

# Server
PORT=3000
NODE_ENV=production

# CORS
ADMIN_FRONTEND_URL=https://your-admin-frontend.vercel.app,http://localhost:5173
